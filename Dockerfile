FROM tomcat:10.1-jdk17

# -----------------------------------------------------------------------------
# Image Metadata
# -----------------------------------------------------------------------------
LABEL maintainer="Muralidhar G"
LABEL application="automation-deployment"
LABEL description="Enterprise DevSecOps Demo Application"

# -----------------------------------------------------------------------------
# Build Arguments
# -----------------------------------------------------------------------------
ARG APP_VERSION=1.0.0

ENV APP_VERSION=${APP_VERSION}

# -----------------------------------------------------------------------------
# Clean Default Applications
# -----------------------------------------------------------------------------
RUN rm -rf /usr/local/tomcat/webapps/*

# -----------------------------------------------------------------------------
# Deploy Application
# -----------------------------------------------------------------------------
COPY target/automation-deployment.war \
     /usr/local/tomcat/webapps/ROOT.war

# -----------------------------------------------------------------------------
# Expose Application Port
# -----------------------------------------------------------------------------
EXPOSE 8080

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTHCHECK --interval=30s \
            --timeout=5s \
            --start-period=40s \
            --retries=3 \
CMD curl -f http://localhost:8080/ || exit 1

# -----------------------------------------------------------------------------
# Start Tomcat
# -----------------------------------------------------------------------------
CMD ["catalina.sh", "run"]
